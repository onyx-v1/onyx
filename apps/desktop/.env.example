# Onyx Desktop — Environment

# ── Required ──────────────────────────────────────────────────────────
# The live URL of your deployed Onyx web app.
# This is what the desktop app loads in its window.
# Copy this file to .env and fill in your URL.
ONYX_APP_URL=https://onyx.yourdomain.com

# ── Optional ──────────────────────────────────────────────────────────
# Set to 'development' to open DevTools on launch
NODE_ENV=production
